// ═══════════════════════════════════════════════════════════════
// CF M5 ADDON — เพิ่มต่อท้าย PA Scanner v12
// SSOT: SNIPER_HUD_BIBLE_v1.1 §3.1
// ═══════════════════════════════════════════════════════════════
//
// วิธีใช้: Copy ทุกบรรทัดด้านล่างนี้ไปวางต่อท้ายโค้ด PA Scanner v12
// ที่มีอยู่ (ก่อน indicator สิ้นสุด / หลัง plotshape สุดท้าย)
//
// ข้อกำหนด Pine v6:
//   - One Statement Per Line (ห้าม ; chain)
//   - lookahead_off เสมอ (ไม่ใช้ lookahead=barmerge.lookahead_on)
//   - ตัดสิน CF ด้วยแท่งปิด [1] (barstate.isconfirmed)
// ═══════════════════════════════════════════════════════════════

// ── §3.1 Grid Level ─────────────────────────────────────────────
float nearestGrid = math.round(close / 5.0) * 5.0

// ── ดึงข้อมูล M5 ด้วย request.security (ป้องกัน look-ahead) ─────
// ใช้ barmerge.lookahead_off เสมอ
float m5Close = request.security(
     syminfo.tickerid,
     "5",
     close[1],
     lookahead = barmerge.lookahead_off
     )

float m5Grid = request.security(
     syminfo.tickerid,
     "5",
     math.round(close[1] / 5.0) * 5.0,
     lookahead = barmerge.lookahead_off
     )

// ── CF M5 State (var = คงค่าข้ามแท่ง) ──────────────────────────
var int  cfCount   = 0        // จำนวนแท่งติดกัน
var int  cfDir     = 0        // 1=buy, -1=sell, 0=neutral
var int  cfCountPrev = 0      // ตรวจ change

// ── นับ CF M5 ทุก confirmed bar ──────────────────────────────────
if barstate.isconfirmed
    bool m5BuySide  = m5Close > m5Grid
    bool m5SellSide = m5Close < m5Grid

    if m5BuySide
        if cfDir == 1
            cfCount := cfCount + 1
        else
            cfCount := 1
            cfDir   := 1
    else if m5SellSide
        if cfDir == -1
            cfCount := cfCount + 1
        else
            cfCount := 1
            cfDir   := -1
    else
        // แท่งนี้ปิดที่กรอบพอดี (= reset)
        cfCount := 0
        cfDir   := 0

// ── cfPass ───────────────────────────────────────────────────────
bool cfPass = cfCount >= 3

// ── ส่ง CF_UPDATE alert เฉพาะเมื่อ cfCount เปลี่ยน ─────────────
// (ประหยัด request · ไม่ spam ทุก bar)
bool cfChanged = cfCount != cfCountPrev

if barstate.isconfirmed and cfChanged
    string cfDirStr = cfDir == 1 ? "buy" : cfDir == -1 ? "sell" : "neutral"
    string cfStatus = cfPass ? "READY" : "WAIT"

    // Payload JSON (ส่งผ่าน Webhook URL เดิมที่ /alerts)
    alert(
         '{"type":"CF_UPDATE",'     +
         '"ticker":"'               + syminfo.ticker          + '",'  +
         '"interval":"'             + timeframe.period        + '",'  +
         '"cf_count":'              + str.tostring(cfCount)   +  ','  +
         '"cf_pass":'               + (cfPass ? "true" : "false")     +  ','  +
         '"cf_dir":"'               + cfDirStr                + '",'  +
         '"cf_status":"'            + cfStatus                + '",'  +
         '"grid_level":'            + str.tostring(m5Grid, "#.##") +  ','  +
         '"close":'                 + str.tostring(m5Close, "#.##")  +
         '}',
         alert.freq_once_per_bar_close
         )

    cfCountPrev := cfCount

// ═══════════════════════════════════════════════════════════════
// ALERT TEMPLATE ที่ต้องตั้งใน TradingView:
//
//   Alert Name  : DIAMOND CF M5 Update
//   Condition   : (indicator ที่ add addon นี้) → CF_UPDATE alert
//   Webhook URL : https://web-production-f6b1.up.railway.app/alerts
//   Message     : {{strategy.order.alert_message}}
//                 ← ใช้ค่า default (Pine ส่ง JSON ผ่าน alert() เอง)
//   Frequency   : Once Per Bar Close
//
// ⚠️ ไม่ต้อง set custom message — Pine จัดการ JSON ให้หมดแล้ว
// ═══════════════════════════════════════════════════════════════
